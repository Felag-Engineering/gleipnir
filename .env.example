# Gleipnir — environment configuration
# Copy this file to .env and fill in values before running.
# The only required change for local dev is setting ANTHROPIC_API_KEY.

# Required: Anthropic API key used by the agent runner.
# Obtain one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# SQLite database file path inside the container.
# The default works for the Docker Compose volume mount.
GLEIPNIR_DB_PATH=/data/gleipnir.db

# Internal HTTP listen address for the Go API server.
# Change only if you need to avoid a port conflict inside the container.
GLEIPNIR_LISTEN_ADDR=:8080

# Host port exposed by docker-compose for the UI.
# The UI will be reachable at http://localhost:<GLEIPNIR_PORT>
GLEIPNIR_PORT=3000

# ---------------------------------------------------------------------------
# NOT YET IMPLEMENTED — these variables are reserved but have no effect.
# ---------------------------------------------------------------------------

# Optional basic auth credentials (reserved for v0.4).
GLEIPNIR_AUTH_USER=
GLEIPNIR_AUTH_PASS=

# Log verbosity for the Go API server (reserved for future use).
# Valid values when implemented: debug, info, warn, error
GLEIPNIR_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Integration testing — start with: docker compose --profile integrations up
# ---------------------------------------------------------------------------

# Todoist MCP server
# Obtain your API token from: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Mealie MCP server
# Your Mealie instance URL — must be reachable from inside Docker (use LAN IP or host.docker.internal, not localhost)
# Example: http://192.168.1.50:9000
MEALIE_BASE_URL=

# Mealie API key — generate from: Mealie UI → avatar → Profile → API Tokens
MEALIE_API_KEY=

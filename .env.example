# Gleipnir — environment configuration
# Copy this file to .env and fill in values before running.
# The only required change for local dev is setting ANTHROPIC_API_KEY.

# Required: Anthropic API key used by the agent runner.
# Obtain one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# SQLite database file path inside the container.
# The default works for the Docker Compose volume mount.
GLEIPNIR_DB_PATH=/data/gleipnir.db

# Internal HTTP listen address for the Go API server.
# Change only if you need to avoid a port conflict inside the container.
GLEIPNIR_LISTEN_ADDR=:8080

# Host port exposed by docker-compose for the UI (nginx).
# The UI will be reachable at http://localhost:<GLEIPNIR_PORT>
GLEIPNIR_PORT=3000

# Optional basic auth credentials — NOT YET IMPLEMENTED (reserved for v0.4).
# Leave blank for now.
GLEIPNIR_AUTH_USER=
GLEIPNIR_AUTH_PASS=

# Log verbosity for the Go API server — NOT YET IMPLEMENTED (reserved for future use).
# Valid values when implemented: debug, info, warn, error
GLEIPNIR_LOG_LEVEL=info
